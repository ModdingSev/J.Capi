# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
# Contraseña del usuario de PostgreSQL (genera una segura y no la cambies)
POSTGRES_PASSWORD=CAMBIA_ESTO

# URL interna del backend hacia el contenedor postgres
# (jcapi-postgres es el nombre del servicio en docker-compose)
DATABASE_URL="postgresql://jcapi_user:CAMBIA_ESTO@jcapi-postgres:5432/jcapi_db?schema=public"

# ─── BACKEND ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# URL del frontend (usada para CORS) — IP del VPS mientras no haya dominio
FRONTEND_URL=http://72.60.213.92:3008

# Contraseña del panel de administración del backend
ADMIN_PASSWORD=CAMBIA_ESTO

# Clave secreta para el agente de sincronización de stock (ClassicGes)
SYNC_API_KEY=CAMBIA_ESTO

# ─── BRAVE IMAGE SEARCH (imágenes por EAN) ────────────────────────────────────
# Registro gratuito en api.search.brave.com → 2000 búsquedas/mes
BRAVE_SEARCH_API_KEY=CAMBIA_ESTO

# ─── NOTAS ────────────────────────────────────────────────────────────────────
# Las variables NEXT_PUBLIC_* del frontend se hornean en el build de Docker.
# El deploy.sh las pasa como --build-arg automáticamente usando VPS_IP.
# No hace falta añadirlas aquí.
